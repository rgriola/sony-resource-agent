# Backend — Provider Selection (plug-and-play)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE_PROVIDER=faiss

# API Keys (set only the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Custom / Self-Hosted Provider (optional)
CUSTOM_LLM_ENDPOINT=
CUSTOM_LLM_API_KEY=

# Ingestion
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# Retrieval
TOP_K_RETRIEVAL=8
TOP_K_AFTER_RERANK=4
VECTOR_STORE_PATH=./data/faiss_index

# CORS
CORS_ORIGINS=["http://localhost:3000"]
