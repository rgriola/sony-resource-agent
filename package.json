{
  "name": "pdf-manual-expert",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && ./venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "install:all": "npm --prefix frontend install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
